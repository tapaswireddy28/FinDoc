# Copy this file to `.env` and fill in your token.
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
#
# The backend reads LLMFOUNDRY_TOKEN from .env at startup, so you never pass it
# on the command line — run the server with just `uvicorn app:app`.
LLMFOUNDRY_TOKEN=your-llmfoundry-token-here
